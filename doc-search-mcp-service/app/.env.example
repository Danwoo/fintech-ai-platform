# 실 인프라 사용 여부 — false(기본)면 Milvus/Redis/임베딩/리랭커 없이 MOCK 금융 문서로 단독 동작.
# true 면 아래 Milvus·Redis·임베딩·리랭커 연결값이 필요하다.
USE_REAL_API=false

# Milvus 벡터 DB (14 분야 컬렉션 — USE_REAL_API=true 일 때만 사용)
MILVUS_DB_HOST=http://198.51.100.35:19530
MILVUS_DB_TOKEN=CHANGE_ME
MILVUS_DB_NAME=finance_doc_topic

# Redis (BM25 sparse 모델 저장소 — USE_REAL_API=true 일 때만 사용)
REDIS_DB_HOST=198.51.100.35
REDIS_DB_PORT=6379
REDIS_DB_PASSWORD=CHANGE_ME

# 임베딩/리랭커 (OpenAI 호환 — USE_REAL_API=true 일 때만 사용)
OPENAI_EMBEDDING_URL=http://198.51.100.35:18080/embedding/v1
OPENAI_EMBEDDING_MODEL_NAME=BAAI/bge-m3
OPENAI_EMBEDDING_API_KEY=CHANGE_ME
OPENAI_RERANKER_URL=http://198.51.100.35:18080/reranker/v1/rerank
OPENAI_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
OPENAI_API_KEY=CHANGE_ME

# 워크스페이스 문서 인제스트 — pgvector 벡터 스토어 (host 비우면 pg 없이 MOCK 동작)
DOC_VECTOR_DB_HOST=
DOC_VECTOR_DB_PORT=5432
DOC_VECTOR_DB_NAME=docsearch
DOC_VECTOR_DB_USER=docsearch
DOC_VECTOR_DB_PASSWORD=CHANGE_ME
WORKSPACE_TABLE=workspace_doc_chunk
EMBEDDING_DIM=1024

# 텍스트 추출 파서 — opensource(pypdf, 기본) / upstage(후속 슬라이스, 미구현)
DOC_PARSER=opensource

# 인증
JWT_SECRET="CHANGE_ME"
