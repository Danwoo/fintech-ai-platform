# .env.development / .env.staging / .env.production 로 복사 후 값 채우기

# 브로커리지/포트폴리오 데이터 소스
# 기본은 in-memory MOCK — 아래 값 없이도 즉시 동작한다(공개 종목 기반 샘플 포트폴리오).
# 실 브로커리지 API 를 쓰려면 USE_REAL_API=true 로 두고 BASE_URL·TOKEN 을 채운다.
USE_REAL_API=false
BROKERAGE_API_BASE_URL=
BROKERAGE_API_TOKEN=

# 인증 — frontend·타 서비스와 동일값 필수
JWT_SECRET="CHANGE_ME"
