# .env.development / .env.staging / .env.production 로 복사 후 값 채우기

# 데이터베이스 (FILE)
FILE_SQL_DB_DRIVER=mssql+pyodbc
FILE_SQL_DB_ODBC_DRIVER="ODBC Driver 18 for SQL Server"
FILE_SQL_DB_HOST=localhost
FILE_SQL_DB_PORT=1433
FILE_SQL_DB_NAME=fullstack_file_template
FILE_SQL_DB_USER=CHANGE_ME
FILE_SQL_DB_PASSWORD=CHANGE_ME

# 인증
JWT_SECRET="CHANGE_ME"

# SFTP
SFTP_HOST=localhost
SFTP_PORT=2022
SFTP_USERNAME=CHANGE_ME
SFTP_PASSWORD=CHANGE_ME
SFTP_BASE_PATH=/upload