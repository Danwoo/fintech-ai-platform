# .env.development / .env.staging / .env.production 로 복사 후 값 채우기 (env-cmd 로딩)

# 데이터베이스
DATABASE_URL="sqlserver://localhost:1433;database=fullstack_frontend_template;user=CHANGE_ME;password=CHANGE_ME;encrypt=DANGER_PLAINTEXT;"

# EMAIL
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="465"
EMAIL_USER="CHANGE_ME"
EMAIL_PASSWORD="CHANGE_ME"
