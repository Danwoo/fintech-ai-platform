{
  "name": "fullstack-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint . --fix",
    "postinstall": "prisma generate",
    "dev": "env-cmd -f .env.development next dev",
    "build": "env-cmd -f .env.production prisma generate && env-cmd -f .env.production next build",
    "start": "env-cmd -f .env.production next start",
    "dev:start": "env-cmd -f .env.development next start",
    "dev:build": "env-cmd -f .env.development prisma generate && env-cmd -f .env.development next build",
    "staging:build": "env-cmd -f .env.staging prisma generate && env-cmd -f .env.staging next build",
    "staging:start": "env-cmd -f .env.staging next start",
    "dev:prisma:push": "env-cmd -f .env.development prisma db push",
    "dev:prisma:studio": "env-cmd -f .env.development prisma studio",
    "staging:prisma:push": "env-cmd -f .env.staging prisma db push",
    "staging:prisma:studio": "env-cmd -f .env.staging prisma studio",
    "prod:prisma:push": "env-cmd -f .env.production prisma db push",
    "prod:prisma:studio": "env-cmd -f .env.production prisma studio"
  },
  "//kysely": "임시 핀 — @better-auth/kysely-adapter 1.6.12 가 kysely 0.29(DEFAULT_MIGRATION_TABLE 제거)에 미대응해 깨짐. adapter 수정판(1.6.13+) 적용되면 이 kysely 직접 의존성 제거",
  "dependencies": {
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "axios": "^1.16.1",
    "better-auth": "^1.6.11",
    "date-fns": "^4.3.0",
    "devextreme": "^24.2.15",
    "devextreme-exceljs-fork": "^4.4.10",
    "devextreme-react": "^24.2.15",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "file-saver": "^2.0.5",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.17.0",
    "kysely": "^0.28.17",
    "next": "^16.2.6",
    "nodemailer": "^8.0.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@prisma/generator-helper": "^7.8.0",
    "@types/file-saver": "^2.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "autoprefixer": "^10.5.0",
    "env-cmd": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
