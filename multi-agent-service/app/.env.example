# MCP 서버 (market-data/disclosure/news/web/doc-search — process-compose dev 포트)
MCP_SERVERS=[{"name": "market-data", "url": "http://localhost:8004"}, {"name": "disclosure", "url": "http://localhost:8005"}, {"name": "news", "url": "http://localhost:8006"}, {"name": "web", "url": "http://localhost:8007"}, {"name": "doc-search", "url": "http://localhost:8008"}]

# LLM (OpenAI 호환 vLLM) — Router(소형) / Generator(대형) 2계층
ROUTER_LLM_BASE_URL=http://198.51.100.35:18080/router/v1
ROUTER_LLM_API_KEY=CHANGE_ME
ROUTER_LLM_MODEL=Qwen/Qwen3.5-9B
GENERATOR_LLM_BASE_URL=http://198.51.100.36:18080/generator/v1
GENERATOR_LLM_API_KEY=CHANGE_ME
GENERATOR_LLM_MODEL=nvidia/Gemma-4-31B-IT-NVFP4

# 인증
JWT_SECRET="CHANGE_ME"

# 공통 DB (ai_chat_history 멀티턴 히스토리 read-only)
MULTI_AGENT_SQL_DB_DRIVER=mssql+pyodbc
MULTI_AGENT_SQL_DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
MULTI_AGENT_SQL_DB_HOST=192.0.2.34
MULTI_AGENT_SQL_DB_PORT=1433
MULTI_AGENT_SQL_DB_NAME=fullstack_frontend_template
MULTI_AGENT_SQL_DB_USER=CHANGE_ME
MULTI_AGENT_SQL_DB_PASSWORD=CHANGE_ME

# langfuse tracing (보류) — 서버 3.5.0 이 OTEL 미지원이라 langchain 1.x(=langfuse v4 OTEL)와 안 맞음.
# 서버가 OTEL 지원 버전이 되면 아래 주석을 풀고 키를 채우면 즉시 작동 (코드는 agent_service 에 이미 있음).
# (보류) LANGFUSE_PUBLIC_KEY=pk-lf-...
# (보류) LANGFUSE_SECRET_KEY=sk-lf-...
# (보류) LANGFUSE_HOST=http://198.51.100.36:11588

# LangSmith tracing (선택) — langchain 1.x 네이티브 관측. API_KEY 채우면 main 이 os.environ 주입해 자동 trace.
# ⚠️ SaaS(api.smith.langchain.com) 라 trace 가 외부로 전송됨 — 사내 데이터(공시·투자 리서치 지식) 주의.
# ⚠️ 개인 계정 키는 git 커밋 금지 — 각자 본인 LangSmith 프로젝트 생성 후 키를 여기 입력 (이 줄은 빈 채로 커밋).
LANGSMITH_API_KEY=CHANGE_ME
LANGSMITH_PROJECT=multi-agent