# .env.development / .env.staging / .env.production 로 복사 후 값 채우기

# 데이터베이스 (DEVACTIVITY)
DEVACTIVITY_SQL_DB_DRIVER=mssql+pyodbc
DEVACTIVITY_SQL_DB_ODBC_DRIVER="ODBC Driver 18 for SQL Server"
DEVACTIVITY_SQL_DB_HOST=localhost
DEVACTIVITY_SQL_DB_PORT=1433
DEVACTIVITY_SQL_DB_NAME=fullstack_devactivity_template
DEVACTIVITY_SQL_DB_USER=CHANGE_ME
DEVACTIVITY_SQL_DB_PASSWORD=CHANGE_ME

# Portfolio MCP
MCP_SERVERS=[{"name": "portfolio", "url": "http://localhost:8002"}]

# LLM (OpenAI 호환 /chat/completions)
LLM_BASE_URL=http://your-llm-host:4000/v1
LLM_MODEL=YOUR_LLM_MODEL
LLM_API_KEY=CHANGE_ME

# 메일 (frontend 와 동일 SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=CHANGE_ME
EMAIL_PASSWORD=CHANGE_ME

# 인증 — frontend·backend 동일값
JWT_SECRET="CHANGE_ME"