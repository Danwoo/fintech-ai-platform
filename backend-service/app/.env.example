# .env.development / .env.staging / .env.production 로 복사 후 값 채우기

# 데이터베이스 (BACKEND)
BACKEND_SQL_DB_DRIVER=mssql+pyodbc
BACKEND_SQL_DB_ODBC_DRIVER="ODBC Driver 18 for SQL Server"
BACKEND_SQL_DB_HOST=localhost
BACKEND_SQL_DB_PORT=1433
BACKEND_SQL_DB_NAME=fintech_backend
BACKEND_SQL_DB_USER=CHANGE_ME
BACKEND_SQL_DB_PASSWORD=CHANGE_ME

# 인증
JWT_SECRET="CHANGE_ME"

# 외부 시장/공시 API 토글 (기본 false → 모의 데이터로 단독 동작)
USE_REAL_API=false

# file-service
FILE_SERVICE_URL=http://localhost:8100
SFTP_BASE_PATH=/upload/backend